NODE_ENV=production
PORT=5000
MONGODB_URI=your-mongodb-atlas-uri

JWT_SECRET=use-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# Comma-separated frontend origins (local + Vercel). No trailing slash.
CORS_ORIGIN=http://localhost:5173,https://your-frontend.vercel.app
# CORS_ORIGIN_REGEX=^https://your-app-.*\.vercel\.app$

MAINTENANCE_DUE_DAY=10
LATE_FEE_PER_DAY=50
PAYMENT_GATEWAY_BASE_URL=https://payments.clave.local/pay
